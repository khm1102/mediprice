# Database
# 로컬 개발: jdbc:postgresql://localhost:5432/mediprice
# Docker Compose: jdbc:postgresql://db:5432/mediprice
DB_URL=jdbc:postgresql://localhost:5432/mediprice
DB_USERNAME=admin
# 미지정 시 앱 부팅 실패 (의도). 운영은 강한 비밀번호 필수
DB_PASSWORD=<your-db-password>
# HikariCP 풀 (Tomcat thread 수와 균형. 기본 30/10 권장)
DB_POOL_SIZE=30
DB_MIN_IDLE=10
DB_MAX_LIFETIME=1800000
# 운영은 30000 (30s) 권장. 0 = 비활성
DB_LEAK_DETECTION=0

# JPA
# 운영 환경에서는 반드시 validate 사용 (update는 데이터 손실 위험)
JPA_DDL_AUTO=update
# 개발 시에만 true 권장 (운영 PII 노출 위험)
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# JWT
# 32바이트(256비트) 이상의 랜덤 문자열 필수 (HMAC-SHA256). 미지정 시 부팅 실패.
# 생성 예: openssl rand -base64 48
JWT_SECRET=<replace-with-random-32-byte-key>
JWT_EXPIRATION=86400000

# Kakao Map
KAKAO_MAP_KEY=<your-kakao-key>

# HIRA API
HIRA_API_KEY=<your-hira-key>

# Cache
CACHE_TTL_SECONDS=3600
GUEST_SEARCH_LIMIT=3

# CORS (콤마로 다중 origin 지정 가능)
CORS_ALLOWED_ORIGINS=http://localhost:8080

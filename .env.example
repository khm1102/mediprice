# Database
# 로컬 개발: jdbc:postgresql://localhost:5432/mediprice
# Docker Compose: jdbc:postgresql://db:5432/mediprice
DB_URL=jdbc:postgresql://localhost:5432/mediprice
DB_USERNAME=admin
DB_PASSWORD=<your-db-password>

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# JWT
JWT_SECRET=<your-jwt-secret>
JWT_EXPIRATION=86400000

# Kakao Map
KAKAO_MAP_KEY=<your-kakao-key>

# HIRA API
HIRA_API_KEY=<your-hira-key>

# Cache
CACHE_TTL_SECONDS=3600
GUEST_SEARCH_LIMIT=3
